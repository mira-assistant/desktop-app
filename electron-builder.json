{
  "appId": "com.mira.app",
  "productName": "Mira App",
  "files": [
    "dist/**/*",
    "renderer/dist/**/*",
    "package.json",
    ".env.production"
  ],
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "mira-assistant",
    "repo": "desktop-app"
  },
  "win": {
    "target": "nsis",
    "icon": "resources/icon.png"
  },
  "mac": {
    "target": "dmg",
    "icon": "resources/icon.png"
  }
}