{
  "name": "Mira App",
  "version": "1.0.1",
  "main": "dist/main/background.js",
  "scripts": {
    "clean": "rimraf dist renderer/.next renderer/out release",
    "prebuild": "npm run clean",
    "dev": "concurrently -n \"NEXT,MAIN,ELEC\" -c \"magenta,blue,green\" \"next dev renderer\" \"tsc -p main/tsconfig.json --watch\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "next build renderer && tsc -p main/tsconfig.json",
    "start": "npm run build && cross-env NODE_ENV=production electron .",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ricky0123/vad-react": "^0.0.36",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "keytar": "^7.9.0",
    "motion": "^12.24.7",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/keytar": "^4.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}